# Claude Gateway — Environment Configuration
# Copy this file to .env and fill in your values.
# .env is gitignored and will NEVER be committed.

# ── Network ───────────────────────────────────────────────────────────────────

# Port the server listens on
PORT=8642

# Bind address. Use 127.0.0.1 if behind a reverse proxy (recommended).
# Use 0.0.0.0 only if you need direct external access and have a firewall.
HOST=127.0.0.1

# ── Security ──────────────────────────────────────────────────────────────────

# REQUIRED: Set a strong random API key. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Leave blank to disable auth (NOT recommended for networked use).
API_KEY=

# RESTRICTED_MODE disables the /execute shell endpoint entirely.
# Only /generate-claude will be available. Recommended for public deployments.
RESTRICTED_MODE=true

# ── Shell (only relevant when RESTRICTED_MODE=false) ──────────────────────────

# Force a specific shell. Leave blank for auto-detection.
# Examples: bash, sh, powershell, cmd
FORCE_SHELL=

# Maximum seconds a shell command may run before being killed
COMMAND_TIMEOUT=120

# Maximum bytes captured from stdout or stderr (default 1 MB)
MAX_OUTPUT_BYTES=1048576

# Maximum characters allowed in a single command
MAX_COMMAND_LENGTH=8192

# ── Logging ───────────────────────────────────────────────────────────────────

# Path for the rotating audit log (records every /execute call)
LOG_FILE=claude_server.log
